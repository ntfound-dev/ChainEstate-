# RPC
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Wallet — replace with your actual private key (without 0x prefix)
PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
ADMIN_ADDRESS=YOUR_WALLET_ADDRESS_HERE

# Block Explorer
ARBISCAN_API_KEY=YOUR_ARBISCAN_KEY_HERE

# USDT testnet address — leave empty to auto-deploy MockERC20
USDT_ADDRESS=

# Treasury wallet (can be same as deployer for testing)
TREASURY_ADDRESS=YOUR_WALLET_ADDRESS_HERE

# IPFS / Pinata (optional, for metadata uploads)
PINATA_API_KEY=
PINATA_SECRET=
